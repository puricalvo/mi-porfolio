---
interface Props {
  href: string;
  text: string;
  variant?: "primary" | "secondary" | "outline" | "success";
  target?: string;
}

const {
  href,
  text,
  variant = "primary",
  target = "_blank",
} = Astro.props;

const variants = {
  primary:
    "bg-blue-500 hover:bg-blue-400 text-white",

  secondary:
      "bg-slate-700 hover:bg-slate-600 border border-slate-600 text-white",

  outline:
     "bg-transparent hover:bg-slate-700 border border-slate-600 text-white",

  success:
    "bg-emerald-600 hover:bg-emerald-500 text-white",
};
---

<a
  href={href}
  target={target}
  rel="noopener noreferrer"
  class={`inline-flex items-center justify-center min-w-36 px-5 sm:px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:scale-105 ${variants[variant]}`}
>
  {text}
</a>