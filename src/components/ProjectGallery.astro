---
interface Image {
    src: string;
    title: string;
}

interface Props {
    images: Image[];
}

const { images } = Astro.props as Props;
---

<div class="relative" data-gallery>

    <div class="overflow-hidden rounded-2xl border border-slate-700 mb-6 sm:mb-8">

        <img
            id="gallery-image"
            src={images[0].src}
            alt={images[0].title}
            class="w-full h-auto transition-opacity duration-500"
        />

    </div>


    <p
        id="gallery-title"
        class="mt-5 text-center text-slate-400 text-sm"
    >
        {images[0].title}
    </p>


    <div class="flex items-center justify-center gap-6 mt-4">


        <button
            id="prev-button"
            type="button"
            class="text-blue-400 hover:text-white transition duration-200 hover:scale-110 cursor-pointer"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
                class="w-6 h-6"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.75 19.5 8.25 12l7.5-7.5"
                />
            </svg>
        </button>


        <div id="gallery-dots" class="flex gap-2">

            {
                images.map((_, index) => (
                    <span
                        class:list={[
                            "w-2 h-2 rounded-full transition",
                            index === 0
                                ? "bg-blue-500"
                                : "bg-slate-600",
                        ]}
                        data-dot={index}
                    ></span>
                ))
            }

        </div>


        <button
            id="next-button"
            type="button"
            class="text-blue-400 hover:text-white transition duration-200 hover:scale-110 cursor-pointer"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
                class="w-6 h-6"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8.25 4.5 15.75 12l-7.5 7.5"
                />
            </svg>
        </button>


    </div>

</div>


<script is:inline define:vars={{ images }}>

const image = document.querySelector("#gallery-image");
const title = document.querySelector("#gallery-title");

const prev = document.querySelector("#prev-button");
const next = document.querySelector("#next-button");

const dots = document.querySelectorAll("[data-dot]");


let current = 0;


function updateGallery(){

    image.classList.add("opacity-0");


    setTimeout(()=>{

        image.src = images[current].src;
        image.alt = images[current].title;

        title.textContent = images[current].title;


        dots.forEach((dot,index)=>{

            if(index === current){

                dot.classList.remove("bg-slate-600");
                dot.classList.add("bg-blue-500");

            } else {

                dot.classList.remove("bg-blue-500");
                dot.classList.add("bg-slate-600");

            }

        });


        image.classList.remove("opacity-0");


    },250);

}



prev.addEventListener("click",()=>{

    current--;

    if(current < 0){
        current = images.length - 1;
    }

    updateGallery();

});



next.addEventListener("click",()=>{

    current++;

    if(current >= images.length){
        current = 0;
    }

    updateGallery();

});



dots.forEach((dot,index)=>{

    dot.addEventListener("click",()=>{

        current = index;

        updateGallery();

    });

});

</script>