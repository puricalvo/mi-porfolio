---
import ProjectGallery from './ProjectGallery.astro';
import Badge from "./Badge.astro";
import Button from "./Button.astro";

const { project } = Astro.props;
---

<div class="bg-slate-800 border border-slate-700 rounded-2xl overflow-hidden hover:border-blue-500 transition-all duration-300 group">

    <div class="p-5 sm:p-8">

        <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-blue-500 text-white text-xs font-semibold">
            🚀 Proyecto Principal
        </span>

            <h2 class="text-2xl sm:text-3xl font-bold group-hover:text-blue-400 transition-colors">
                {project.title}
            </h2>
        </div>

        <p class="text-slate-400 leading-relaxed mb-8 text-base sm:text-lg">
            {project.description}
        </p>

        <div class="mb-10">
            <ProjectGallery images={project.gallery} />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
            {
                project.features.map((feature: string) => (
                    <div class="flex items-center gap-2 text-slate-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        <span>{feature}</span>
                    </div>
                ))
            }
        </div>

        <div class="flex flex-wrap gap-2 mb-8">
            {project.tags.map((tag: string) => (
                <Badge text={tag} />
            ))}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:flex gap-4 mt-6">

            <Button
                href={project.websiteUrl}
                text="🌍 Ver Web"
                variant="success"
            />

            <Button
                href={project.demoUrl}
                text="🌐 Ver Demo"
                variant="primary"
            />

            <Button
                href={project.codeUrl}
                text="💻 Código"
                variant="secondary"
            />

            <Button
                href={project.installerUrl}
                text="⚙️ Instalador"
                variant="outline"
            />

        </div>

    </div>

</div>