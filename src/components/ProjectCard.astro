---
// src/components/ProjectCard.astro
interface Props {
	title: string;
	description: string;
	tags: string[];
	demoUrl: string;
	codeUrl: string;
}

const { title, description, tags, demoUrl, codeUrl } = Astro.props;
---

<div class="bg-slate-800 border border-slate-700 rounded-2xl overflow-hidden hover:border-blue-500 transition-all group">
	<div class="p-8">
		<div class="flex flex-wrap gap-2 mb-4">
			{tags.map((tag) => (
				<span class="bg-slate-900 text-blue-300 px-3 py-1 rounded-full text-xs font-semibold border border-blue-900/30">
					{tag}
				</span>
			))}
		</div>
		<h3 class="text-2xl font-bold mb-4 group-hover:text-blue-400 transition-colors">{title}</h3>
		<p class="text-slate-400 mb-6 leading-relaxed">
			{description}
		</p>
		<div class="flex gap-4">
			<a href={demoUrl} target="_blank" class="text-blue-400 font-bold hover:underline">Ver Demo →</a>
			<a href={codeUrl} target="_blank" class="text-slate-300 hover:text-white">Código Fuente</a>
		</div>
	</div>
</div>